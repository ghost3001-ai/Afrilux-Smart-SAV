DJANGO_DEBUG=false
DJANGO_SECRET_KEY=change-this-secret-before-production
DJANGO_SERVE_STATIC_LOCAL=true
DJANGO_WAIT_FOR_DB=true
DJANGO_RUN_MIGRATIONS_ON_STARTUP=true
DJANGO_COLLECTSTATIC_ON_STARTUP=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=afrilux_sav
DJANGO_DB_USER=afrilux
DJANGO_DB_PASSWORD=afrilux
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
DJANGO_DB_SSLMODE=prefer
DJANGO_DB_CONN_MAX_AGE=60

REDIS_URL=redis://127.0.0.1:6379/1
API_DEFAULT_PAGE_SIZE=25
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REASONING_EFFORT=medium

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@afrilux.local
INBOUND_EMAIL_IMAP_HOST=imap.example.com
INBOUND_EMAIL_IMAP_PORT=993
INBOUND_EMAIL_IMAP_USER=
INBOUND_EMAIL_IMAP_PASSWORD=
INBOUND_EMAIL_IMAP_USE_SSL=true
INBOUND_EMAIL_IMAP_MAILBOX=INBOX
INBOUND_EMAIL_IMAP_SEARCH=UNSEEN

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+10000000000
TWILIO_WHATSAPP_FROM=whatsapp:+10000000000
TWILIO_STATUS_CALLBACK_URL=

FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=

SAV_PUBLIC_BASE_URL=http://127.0.0.1:8000
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=false
CSRF_COOKIE_HTTPONLY=false
CSRF_COOKIE_SAMESITE=Lax
